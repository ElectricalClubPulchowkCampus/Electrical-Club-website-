{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "summary": {
      "type": "text"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "gallery": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "startDate": {
      "type": "date"
    },
    "endDate": {
      "type": "date"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "workshop",
        "seminar",
        "competition",
        "cultural",
        " sports",
        " other"
      ]
    },
    "status_event": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "upcoming",
        "ongoing",
        "completed",
        "cancelled"
      ]
    },
    "order": {
      "type": "integer"
    },
    "venue": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::venue.venue",
      "inversedBy": "events"
    },
    "registrations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::registration.registration",
      "mappedBy": "event"
    },
    "organizer": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::team.team"
    },
    "description": {
      "type": "text"
    },
    "fee": {
      "type": "integer"
    },
    "shift": {
      "type": "component",
      "component": "shared.shift",
      "repeatable": true
    }
  }
}
